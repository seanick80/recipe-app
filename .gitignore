# Swift
.build/
*.exe
*.o
DerivedData/
*.xcuserdata

# xcodegen: project is generated from project.yml at build time
RecipeApp/RecipeApp.xcodeproj/

# CI-only: shared parser modules copied from SharedLogic/ at build time
RecipeApp/RecipeApp/Parsers/

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Claude Code
.claude/

# CoreML models are checked in under RecipeApp/RecipeApp/MLModels/.
# Regenerate with: scripts/update-models.sh (requires macOS + Python).
# Ignore .mlpackage dirs anywhere ELSE (e.g. build artifacts, caches).
*.mlpackage
!RecipeApp/RecipeApp/MLModels/*.mlpackage

# CI artifacts (downloaded by poll-build.sh)
build/

# Layout bench: results are generated locally, not tracked
data/layout-bench/results/
# Test images are personal photos — not tracked (too large, possibly private)
data/layout-bench/images/*
!data/layout-bench/images/.gitkeep

# YOLO model weights (large binaries, re-download with ultralytics)
*.pt

# Pantry bench: annotated images are generated output, not source
data/pantry-bench/results/*_annotated.jpg

# Env
.env

# Secrets — NEVER commit anything from here.
# This directory holds local key material (ASC API .p8, signing .p12,
# private keys, CSRs) used for the one-time signing identity ceremony.
# Persistent storage for these lives in Codemagic's signing-identity store
# and/or a password manager, not the repo.
secrets/
*.p8
*.p12
*.cer
*.pem
*.mobileprovision
*.key
AuthKey_*.p8
