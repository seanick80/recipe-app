#!/usr/bin/env bash
# .githooks/pre-push — runs before every `git push`.
#
# Enforces the FULL build: lint + tests + config validation + clean-tree check.
# This is the last line of defense before changes hit GitHub / Codemagic.
#
# To activate (one-time per clone):
#   git config core.hooksPath .githooks

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo ""
echo "################################################################"
echo "# pre-push: full build + config validation"
echo "################################################################"

./scripts/build.sh full

# Git LFS pre-push hook — uploads tracked large files.
if command -v git-lfs >/dev/null 2>&1; then
    git lfs pre-push "$@"
fi
