#!/usr/bin/env bash
# .githooks/pre-commit — runs before every `git commit`.
#
# Enforces: lint + lightweight unit tests.
# Fast by design — if this slows you down, move expensive checks to pre-push.
#
# To activate (one-time per clone):
#   git config core.hooksPath .githooks

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo ""
echo "################################################################"
echo "# pre-commit: lint + lightweight unit tests"
echo "################################################################"

./scripts/build.sh quick
